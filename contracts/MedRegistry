pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/access/AccessControl.sol";

contract MedRegistry is ERC721, AccessControl {

    bytes32 public constant MANUFACTURER_ROLE = keccak256("MANUFACTURER_ROLE");

    uint256 private _tokenIdCounter;

    struct Batch {
        uint256 batchId;
        string medicineName;
        string manufacturerDetails;
        uint256 manufacturingDate;
        uint256 expiryDate;
        string handlingRequirements;
        string storageConditions;
        string status;
        address currentOwner;
    }

    mapping(uint256 => Batch) public batches;

    event BatchMinted(uint256 indexed tokenId, address indexed manufacturer, string medicineName);

    constructor() ERC721("MedLedger", "MEDL") {
        _grantRole(DEFAULT_ADMIN_ROLE, msg.sender);
    }

    function mint(
        address to,
        string memory medicineName,
        string memory manufacturerDetails,
        uint256 manufacturingDate,
        uint256 expiryDate,
        string memory handlingRequirements,
        string memory storageConditions
    ) public onlyRole(MANUFACTURER_ROLE) returns (uint256) {
        
        uint256 tokenId = _tokenIdCounter;
        _tokenIdCounter++;

        _safeMint(to, tokenId);

        batches[tokenId] = Batch({
            batchId: tokenId,
            medicineName: medicineName,
            manufacturerDetails: manufacturerDetails,
            manufacturingDate: manufacturingDate,
            expiryDate: expiryDate,
            handlingRequirements: handlingRequirements,
            storageConditions: storageConditions,
            status: "active",
            currentOwner: to
        });

        emit BatchMinted(tokenId, msg.sender, medicineName);
        return tokenId;
    }

    function addManufacturer(address account) public onlyRole(DEFAULT_ADMIN_ROLE) {
        grantRole(MANUFACTURER_ROLE, account);
    }

    function getBatch(uint256 tokenId) public view returns (Batch memory) {
        return batches[tokenId];
    }

    function supportsInterface(bytes4 interfaceId)
        public view override(ERC721, AccessControl) returns (bool) {
        return super.supportsInterface(interfaceId);
    }
}
